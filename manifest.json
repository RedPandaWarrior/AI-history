{
  "manifest_version": 3,
  "name": "AI用户消息历史面板",
  "version": "2.0",
  "description": "显示 AI 用户消息历史的 Chrome 扩展",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"]
    }
  ]
}